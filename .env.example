# Solar Agent — Environment variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to the repository (it is in .gitignore).

# ── Docker services ───────────────────────────────────────
N8N_EMAIL=tu@email.com
N8N_PASSWORD=cambia_esto
N8N_URL=http://localhost:5678

FLOWISE_USERNAME=tu@email.com
FLOWISE_PASSWORD=cambia_esto
FLOWISE_URL=http://localhost:3000

# ── External APIs ─────────────────────────────────────────
# Get at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
# Get at: https://console.cloud.google.com → Places API (New)
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Installer details (appear in generated emails) ─────────
EMPRESA_NOMBRE=SolarCáceres
EMPRESA_TELEFONO=927 000 000
EMPRESA_WEB=www.solarcaceres.es
EMPRESA_EMAIL=info@solarcaceres.es

# ── Google Calendar API ────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs → Enable "Google Calendar API"
# 2. Credentials → Create → OAuth 2.0 → Desktop application
# 3. Download the JSON → place it in the agente-solar folder as credentials.json
# 4. On first use, the browser opens for authorisation (creates token_calendar.json)
# 5. GOOGLE_CALENDAR_ID: use "primary" or the email of the specific calendar
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=token_calendar.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_AUTH_EMAIL=tu@email.com    # email of the Google account you authorise Calendar with

# ── Telegram Bot ───────────────────────────────────────────
# 1. Search for @BotFather on Telegram → /newbot → follow the steps
# 2. Save the token BotFather gives you (format: 123456:ABC-DEF...)
# 3. Start a conversation with your bot → go to:
#    https://api.telegram.org/bot{TOKEN}/getUpdates
#    The "chat" → "id" field is your TELEGRAM_CHAT_ID
# 4. To notify a group: add the bot to the group and get the group's chat_id
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# ── Script server (API key to authenticate n8n requests) ───
# If empty, the server accepts without authentication (recommended for local use only)
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
SERVIDOR_API_KEY=

# ── Solar savings calculation ──────────────────────────────
# Average electricity price in Spain (adjust if it changes)
PRECIO_KWH=0.18

# ── Brevo SMTP (for sending emails) ───────────────────────
# 1. Register at https://www.brevo.com (free up to 300/day)
# 2. Go to: SMTP & API → SMTP → Generate a new SMTP Key
# 3. The SMTP username is your Brevo login email
# 4. The SMTP password is the key generated in step 2 (NOT your Brevo account password)
# 5. Verify your sender domain/email at: Senders & IP → Senders
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=tu@email.com          # email you registered with on Brevo
BREVO_SMTP_KEY=xsmtpsib-...           # SMTP key generated in Brevo (starts with xsmtpsib-)
EMAIL_FROM_ADDRESS=info@solarcaceres.es  # must be verified in Brevo as a sender
EMAIL_FROM_NAME=SolarCáceres
